{
  "manifest_version": 3,
  "name": "SideNote",
  "version": "1.0",
  "description": "Write markdown notes in your browser sidebar",

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "permissions": [
    "sidePanel",
    "tabs"
  ],

  "action": {
    "default_title": "Open SideNote"
  },


  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["date-fns.umd.min.js"],
      "run_at": "document_idle"
    }
  ]

}