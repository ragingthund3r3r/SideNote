{
  "manifest_version": 3,
  "name": "SideNote",
  "version": "1.0",
  "description": "Write markdown notes in your browser sidebar",

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "permissions": [
    "sidePanel",
    "tabs",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_title": "Open SideNote",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },


  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["date-fns.umd.min.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
  "16": "icons/icon16.png",
  "32": "icons/icon32.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
  }

}